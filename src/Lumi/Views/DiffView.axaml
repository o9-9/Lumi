<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sc="using:StrataTheme.Controls"
             x:Class="Lumi.Views.DiffView">

  <Panel>
    <DockPanel>
      <!-- Navigation bar -->
      <Border DockPanel.Dock="Top" Padding="8,6" Background="{DynamicResource Brush.SurfaceCard}">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <TextBlock x:Name="ChangeCountText" Classes="caption" VerticalAlignment="Center"
                       Foreground="{DynamicResource Brush.TextTertiary}" Margin="0,0,4,0" />
            <Button x:Name="PrevChangeBtn" Classes="subtle" Padding="4,2" MinHeight="0" Height="24"
                    Width="24" ToolTip.Tip="Previous change" Cursor="Hand">
              <TextBlock Text="▲" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            <Button x:Name="NextChangeBtn" Classes="subtle" Padding="4,2" MinHeight="0" Height="24"
                    Width="24" ToolTip.Tip="Next change" Cursor="Hand">
              <TextBlock Text="▼" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
          </StackPanel>
          <TextBlock x:Name="StatsText" Classes="caption" VerticalAlignment="Center"
                     Foreground="{DynamicResource Brush.TextSecondary}" />
        </DockPanel>
      </Border>

      <!-- Diff content -->
      <ScrollViewer x:Name="DiffScroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="DiffContent" Margin="0,4" />
      </ScrollViewer>
    </DockPanel>

    <!-- Centered loading overlay -->
    <Panel x:Name="LoadingOverlay" IsVisible="False" IsHitTestVisible="False">
      <sc:StrataTypingIndicator x:Name="LoadingIndicator" Label="Loading diff…" IsActive="True"
                                HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Panel>
  </Panel>

</UserControl>
