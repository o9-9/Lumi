<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="using:Lumi.Models"
             xmlns:vm="using:Lumi.ViewModels"
             xmlns:services="using:Lumi.Services"
             xmlns:conv="using:Lumi.Converters"
             xmlns:lc="using:Lumi.Views.Controls"
             xmlns:sc="using:StrataTheme.Controls"
             xmlns:loc="using:Lumi.Localization"
             x:Class="Lumi.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             x:CompileBindings="True">

  <UserControl.Resources>
    <conv:ModelDisplayConverter x:Key="ModelDisplayConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Show Retry on user messages (theme hides it) -->
    <Style Selector="sc|StrataChatMessage:user /template/ Button#PART_RegenerateButton">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <!-- Hide entire action toolbar on assistant messages -->
    <Style Selector="sc|StrataChatMessage:assistant /template/ Border#PART_ActionLayer">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <!-- Compact tool calls: hide the status pill and reduce padding -->
    <Style Selector="sc|StrataAiToolCall.compact /template/ Border#PART_StatusPill">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="sc|StrataAiToolCall.compact /template/ Border#PART_Header">
      <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style Selector="Button#BrowserToggleButton.open">
      <Setter Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
    </Style>
    <Style Selector="Button#BrowserToggleButton.open TextBlock#BrowserToggleText">
      <Setter Property="Foreground" Value="{DynamicResource Brush.AccentDefault}" />
    </Style>
    <Style Selector="Button#BrowserToggleButton.open PathIcon#BrowserToggleIcon">
      <Setter Property="Foreground" Value="{DynamicResource Brush.AccentDefault}" />
    </Style>

    <!-- Token usage badge hover -->
    <Style Selector="Border#TokenUsageBadge:pointerover">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceSubtle}" />
    </Style>

    <!-- ── Panel cross-fade transitions ─────────────────── -->

    <!-- Welcome panel: opacity + hit-testing controlled by .active class -->
    <Style Selector="Panel#WelcomePanel">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.35" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Panel#WelcomePanel.active">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
    </Style>

    <!-- Welcome greeting: subtle slide-up as it fades out -->
    <Style Selector="StackPanel#WelcomeGreeting">
      <Setter Property="RenderTransform" Value="translateY(16px)" />
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.5" Easing="0.2,0 0,1" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Panel#WelcomePanel.active StackPanel#WelcomeGreeting">
      <Setter Property="RenderTransform" Value="translateY(0)" />
    </Style>

    <!-- Chat panel: opacity + hit-testing controlled by .active class -->
    <Style Selector="Panel#ChatPanel">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.45" Easing="CubicEaseOut" Delay="0:0:0.1" />
        </Transitions>
      </Setter>
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Panel#ChatPanel.active">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
    </Style>

    <!-- ── Composer container: animated width + margin transition ── -->
    <Style Selector="StackPanel#ComposerContainer">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="MaxWidth" Duration="0:0:0.55" Easing="0.2,0 0,1" />
          <ThicknessTransition Property="Margin" Duration="0:0:0.55" Easing="0.2,0 0,1" />
        </Transitions>
      </Setter>
      <!-- Default (active chat) state -->
      <Setter Property="MaxWidth" Value="5000" />
      <Setter Property="Margin" Value="12,8,12,10" />
    </Style>
    <Style Selector="StackPanel#ComposerContainer.welcome">
      <Setter Property="MaxWidth" Value="680" />
      <Setter Property="Margin" Value="24,0,24,20" />
    </Style>

    <!-- ── Transcript suggestion chips ── -->
    <Style Selector="WrapPanel#SuggestionChipsRow">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="RenderTransform" Value="translateY(8px)" />
      <Setter Property="IsVisible" Value="False" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="WrapPanel#SuggestionChipsRow.visible">
      <Setter Property="IsVisible" Value="True" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransform" Value="translateY(0)" />
    </Style>

    <Style Selector="Button.transcript-suggestion">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface2}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Height" Value="NaN" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
          <BrushTransition Property="Foreground" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.transcript-suggestion:pointerover">
      <Setter Property="Background" Value="{DynamicResource Brush.ControlHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentSubtle}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>
    <Style Selector="Button.transcript-suggestion:pressed">
      <Setter Property="RenderTransform" Value="scale(0.97)" />
    </Style>
    <Style Selector="Button.transcript-suggestion /template/ Border#PART_Aurora">
      <Setter Property="IsVisible" Value="False" />
    </Style>

    <!-- ── In-chat suggestion chips (smaller than welcome) ── -->
    <Style Selector="WrapPanel#SuggestionChipsRow Button.transcript-suggestion">
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="FontSize" Value="10" />
    </Style>

    <!-- ── Suggestion loading pills (transcript) ── -->
    <Style Selector="Border.suggestion-pill">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface2}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Height" Value="30" />
    </Style>
    <Style Selector="Border.suggestion-pill.pill-a">
      <Style.Animations>
        <Animation Duration="0:0:0.95" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
          <KeyFrame Cue="38%"><Setter Property="Opacity" Value="0.6" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.suggestion-pill.pill-b">
      <Style.Animations>
        <Animation Duration="0:0:0.95" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
          <KeyFrame Cue="18%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
          <KeyFrame Cue="56%"><Setter Property="Opacity" Value="0.6" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.suggestion-pill.pill-c">
      <Style.Animations>
        <Animation Duration="0:0:0.95" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
          <KeyFrame Cue="36%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
          <KeyFrame Cue="74%"><Setter Property="Opacity" Value="0.6" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- ── Welcome suggestion chips (simple, minimal) ── -->
    <Style Selector="WrapPanel#WelcomeSuggestions">
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <!-- Worktree toggle label transitions -->
    <Style Selector="TextBlock.wt-label">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="TextBlock.wt-label.inactive">
      <Setter Property="Opacity" Value="0.45" />
    </Style>
  </UserControl.Styles>

  <UserControl.DataTemplates>

    <!-- ── User message ─────────────────────────────── -->
    <DataTemplate DataType="vm:UserMessageItem">
      <sc:StrataChatMessage Role="User"
                            HorizontalAlignment="Right"
                            MaxWidth="560"
                            Author="{Binding Author}"
                            Timestamp="{Binding TimestampText}"
                            IsEditable="True"
                            EditText="{Binding Content, Mode=OneWay}"
                            EditCommand="{Binding BeginEditCommand}"
                            EditConfirmedCommand="{Binding ConfirmEditCommand}"
                            RegenerateCommand="{Binding ResendCommand}">
        <sc:StrataChatMessage.Content>
          <StackPanel Spacing="6">
            <lc:TranscriptTextContent Text="{Binding Content}" />
            <ContentControl Content="{Binding DisplayAttachments}"
                            IsVisible="{Binding HasAttachments}">
              <ContentControl.DataTemplates>
                <DataTemplate DataType="x:Object">
                  <ItemsControl ItemsSource="{Binding}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="vm:FileAttachmentItem">
                        <sc:StrataFileAttachment FileName="{Binding FileName}"
                                                 FileSize="{Binding FileSize}"
                                                 IconImage="{Binding IconImage}"
                                                 Status="Completed"
                                                 IsRemovable="False" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </DataTemplate>
              </ContentControl.DataTemplates>
            </ContentControl>
            <ContentControl Content="{Binding DisplaySkills}"
                            IsVisible="{Binding HasSkills}">
              <ContentControl.DataTemplates>
                <DataTemplate DataType="x:Object">
                  <ItemsControl ItemsSource="{Binding}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="model:SkillReference">
                        <Border Background="{DynamicResource Brush.AccentSubtle}"
                                CornerRadius="14" Padding="8,4,10,4" Margin="0,0,4,4">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Glyph}" FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </DataTemplate>
              </ContentControl.DataTemplates>
            </ContentControl>
          </StackPanel>
        </sc:StrataChatMessage.Content>
      </sc:StrataChatMessage>
    </DataTemplate>

    <!-- ── Assistant message ────────────────────────── -->
    <DataTemplate DataType="vm:AssistantMessageItem">
      <sc:StrataChatMessage Role="Assistant"
                            HorizontalAlignment="Left"
                            MaxWidth="760"
                            Author="{Binding Author}"
                            Timestamp="{Binding TimestampText}"
                            IsStreaming="{Binding IsStreaming}">
        <sc:StrataChatMessage.Content>
          <StackPanel Spacing="6">
            <lc:TranscriptTextContent Text="{Binding Content}" />

            <!-- Skills section -->
            <ContentControl Content="{Binding DisplaySkills}"
                            IsVisible="{Binding HasSkills}">
              <ContentControl.DataTemplates>
                <DataTemplate DataType="x:Object">
                  <ItemsControl ItemsSource="{Binding}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="model:SkillReference">
                        <Border Background="{DynamicResource Brush.AccentSubtle}"
                                CornerRadius="14" Padding="8,4,10,4" Margin="0,0,4,4">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Glyph}" FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </DataTemplate>
              </ContentControl.DataTemplates>
            </ContentControl>

            <!-- File attachments -->
            <ContentControl Content="{Binding DisplayFileAttachments}"
                            IsVisible="{Binding HasFileAttachments}">
              <ContentControl.DataTemplates>
                <DataTemplate DataType="x:Object">
                  <ItemsControl ItemsSource="{Binding}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="vm:FileAttachmentItem">
                        <sc:StrataFileAttachment FileName="{Binding FileName}"
                                                 FileSize="{Binding FileSize}"
                                                 IconImage="{Binding IconImage}"
                                                 Status="Completed"
                                                 IsRemovable="False" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </DataTemplate>
              </ContentControl.DataTemplates>
            </ContentControl>

            <!-- Sources section -->
            <ContentControl Content="{Binding DisplaySourcesSection}"
                            IsVisible="{Binding HasSources}">
              <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:AssistantMessageItem">
                  <sc:StrataThink Label="{Binding SourcesLabel}">
                    <sc:StrataThink.Content>
                      <ItemsControl ItemsSource="{Binding Sources}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><StackPanel Spacing="2" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="vm:SourceItem">
                            <Button Classes="subtle" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Command="{Binding OpenCommand}"
                                    Padding="6,4" Cursor="Hand">
                              <StackPanel>
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                           Classes="caption" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Domain}" Classes="caption"
                                           Foreground="{DynamicResource Brush.TextTertiary}" />
                              </StackPanel>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </sc:StrataThink.Content>
                  </sc:StrataThink>
                </DataTemplate>
              </ContentControl.DataTemplates>
            </ContentControl>

          </StackPanel>
        </sc:StrataChatMessage.Content>
      </sc:StrataChatMessage>
    </DataTemplate>

    <!-- ── Turn model label (end of turn) ── -->
    <DataTemplate DataType="vm:TurnModelItem">
      <TextBlock Text="{Binding ModelName}"
                 FontSize="10"
                 Foreground="{DynamicResource Brush.TextTertiary}"
                 Margin="0,4,0,0"
                 HorizontalAlignment="Left" />
    </DataTemplate>

    <!-- ── File changes summary (separate item at end of turn) ── -->
    <DataTemplate DataType="vm:FileChangesSummaryItem">
      <sc:StrataThink Label="{Binding Label}">
        <sc:StrataThink.HeaderExtra>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{Binding TotalStatsAdded}"
                       FontSize="{DynamicResource Font.SizeCaption}" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.SuccessDefault}" />
            <TextBlock Text="{Binding TotalStatsRemoved}"
                       FontSize="{DynamicResource Font.SizeCaption}" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.DangerDefault}"
                       IsVisible="{Binding HasTotalRemovals}" />
          </StackPanel>
        </sc:StrataThink.HeaderExtra>
        <sc:StrataThink.Content>
          <ItemsControl ItemsSource="{Binding FileChanges}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Spacing="2" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:FileChangeItem">
                <Button Classes="subtle" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowDiffCommand}"
                        Padding="6,4" Cursor="Hand">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding ActionIcon}" Margin="0,0,6,0"
                               FontSize="13" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center" Margin="8,0,0,0">
                      <TextBlock Text="{Binding StatsAdded}"
                                 FontSize="{DynamicResource Font.SizeCaption}" FontWeight="Medium"
                                 Foreground="{DynamicResource Brush.SuccessDefault}" />
                      <TextBlock Text="{Binding StatsRemoved}"
                                 FontSize="{DynamicResource Font.SizeCaption}" FontWeight="Medium"
                                 Foreground="{DynamicResource Brush.DangerDefault}"
                                 IsVisible="{Binding HasRemovals}" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="{Binding FileName}" Classes="caption" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Directory}" Classes="caption"
                                 Foreground="{DynamicResource Brush.TextTertiary}"
                                 TextTrimming="CharacterEllipsis"
                                 IsVisible="{Binding Directory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </DockPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Plan card (inline in transcript when agent creates/updates a plan) ── -->
    <DataTemplate DataType="vm:PlanCardItem">
      <Button Classes="subtle" HorizontalAlignment="Left"
              HorizontalContentAlignment="Left"
              Command="{Binding OpenCommand}"
              Padding="8,6" Margin="0,4" Cursor="Hand">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <PathIcon Width="14" Height="14" Foreground="{DynamicResource Brush.AccentDefault}"
                    VerticalAlignment="Center">
            <PathIcon.Data>
              <StreamGeometry>M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM17.99 9l-1.41-1.42-6.59 6.59-2.58-2.57-1.42 1.41 4 3.99z</StreamGeometry>
            </PathIcon.Data>
          </PathIcon>
          <TextBlock Text="{Binding StatusText}" Classes="caption" FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.AccentDefault}"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </DataTemplate>

    <!-- ── Error message ─────────────────────────────── -->
    <DataTemplate DataType="vm:ErrorMessageItem">
      <Border Background="{DynamicResource Brush.DangerSubtle}"
              CornerRadius="12" Padding="14,12" Margin="0,4">
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="⚠" FontSize="14" VerticalAlignment="Center"
                       Foreground="{DynamicResource Brush.DangerDefault}" />
            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.DangerDefault}"
                       FontWeight="SemiBold" FontSize="13" />
          </StackPanel>
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- ── Reasoning block ──────────────────────────── -->
    <DataTemplate DataType="vm:ReasoningItem">
      <sc:StrataThink Label="{loc:Str Tool_ReasoningLabel}"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}">
        <sc:StrataThink.Content>
          <lc:TranscriptTextContent Text="{Binding Content}"
                                    PreferPlainText="{Binding IsActive}"
                                    RenderMarkdownWhileStreaming="True" />
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Tool group (collapsible) ─────────────────── -->
    <DataTemplate DataType="vm:ToolGroupItem">
      <sc:StrataThink Label="{Binding Label}"
                      Meta="{Binding Meta}"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}"
                      ProgressValue="{Binding ProgressValue}">
        <sc:StrataThink.Content>
          <ItemsControl ItemsSource="{Binding ToolCalls}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Spacing="3" Width="440" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Single tool (flattened — StrataThink pill) ── -->
    <DataTemplate DataType="vm:SingleToolItem">
      <sc:StrataThink Label="{Binding Label}"
                      Meta="{Binding Meta}"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}">
        <sc:StrataThink.HeaderExtra>
          <Button Classes="subtle" Command="{Binding ShowDiffCommand}"
                  IsVisible="{Binding HasDiff}"
                  Padding="5,0" MinHeight="0" Height="18"
                  Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="3">
              <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         FontSize="9" VerticalAlignment="Center" />
              <TextBlock Text="{loc:Str ShowDiff}" FontSize="9" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </sc:StrataThink.HeaderExtra>
        <sc:StrataThink.Content>
          <StackPanel Spacing="6" MaxWidth="440">
            <!-- Regular tool details -->
            <sc:StrataMarkdown Markdown="{Binding InputParameters}" IsInline="True"
                               IsVisible="{Binding InputParameters, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Text="{Binding MoreInfo}" TextWrapping="Wrap"
                       Classes="caption" Foreground="{DynamicResource Brush.TextSecondary}"
                       IsVisible="{Binding MoreInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <!-- Terminal: command + scrollable output -->
            <Border IsVisible="{Binding IsTerminal}"
                    Background="{DynamicResource Brush.Surface1}"
                    CornerRadius="6" Padding="10,8">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="Auto,6,*">
                  <TextBlock Text="$" FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="12" FontWeight="Bold"
                             Foreground="{DynamicResource Brush.TerminalPreviewPrompt}"
                             VerticalAlignment="Top" />
                  <TextBlock Grid.Column="2" Text="{Binding TerminalCommand}" FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="12" TextWrapping="Wrap"
                             Foreground="{DynamicResource Brush.TerminalPreviewCommand}" />
                </Grid>
                <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Disabled"
                              IsVisible="{Binding TerminalOutput, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                  <TextBlock Text="{Binding TerminalOutput}" FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource Brush.TerminalPreviewOutput}" />
                </ScrollViewer>
              </StackPanel>
            </Border>
          </StackPanel>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Subagent card (standalone turn-level item) ── -->
    <DataTemplate DataType="vm:SubagentToolCallItem">        <sc:StrataThink Label="{Binding Title}"
                        Meta="{Binding Meta}"
                        IsExpanded="{Binding IsExpanded}"
                        IsActive="{Binding IsActive}"
                        ProgressValue="{Binding ProgressValue}">
        <sc:StrataThink.Content>
          <StackPanel Spacing="6">
            <!-- Agent byline — visible only when expanded -->
            <StackPanel Orientation="Horizontal" Spacing="4"
                        Margin="0,0,0,2">
              <Border IsVisible="{Binding IsBackgroundMode}"
                      Background="{DynamicResource Brush.AccentSubtle}"
                      CornerRadius="999" Padding="6,1">
                <TextBlock Text="{Binding ModeLabel}" FontSize="10"
                           Foreground="{DynamicResource Brush.AccentDefault}"
                           FontWeight="SemiBold" />
              </Border>
              <TextBlock Text="{Binding DisplayName}"
                         FontSize="11"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         Opacity="0.8" />
              <TextBlock Text="·"
                         FontSize="11"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         Opacity="0.4"
                         IsVisible="{Binding HasModelName}" />
              <TextBlock Text="{Binding ModelDisplayName}"
                         FontSize="11"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         Opacity="0.6"
                         IsVisible="{Binding HasModelName}" />
            </StackPanel>

            <sc:StrataThink Label="{loc:Str Tool_ReasoningLabel}"
                            IsExpanded="True"
                            IsActive="{Binding IsActive}"
                            IsVisible="{Binding HasReasoningText}">
              <sc:StrataThink.Content>
                <lc:TranscriptTextContent Text="{Binding ReasoningText}"
                                          PreferPlainText="{Binding IsActive}"
                                          RenderMarkdownWhileStreaming="True" />
              </sc:StrataThink.Content>
            </sc:StrataThink>

            <lc:TranscriptTextContent Text="{Binding TranscriptText}"
                                      PreferPlainText="{Binding IsActive}"
                                      IsVisible="{Binding HasTranscriptText}" />

            <ItemsControl ItemsSource="{Binding Activities}"
                          IsVisible="{Binding HasActivities}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><StackPanel Spacing="3" /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>
        </sc:StrataThink.Content>
        </sc:StrataThink>
    </DataTemplate>

    <!-- ── Regular tool call (inside tool group) ────── -->
    <DataTemplate DataType="vm:ToolCallItem">
      <sc:StrataAiToolCall ToolName="{Binding ToolName}"
                           Classes.compact="{Binding IsCompact}"
                           Status="{Binding Status}"
                           IsExpanded="{Binding IsExpanded}"
                           InputParameters="{Binding InputParameters}"
                           MoreInfo="{Binding MoreInfo}"
                           DurationMs="{Binding DurationMs}">
        <sc:StrataAiToolCall.HeaderAction>
          <Button Classes="subtle" Command="{Binding ShowDiffCommand}"
                  IsVisible="{Binding HasDiff}"
                  Padding="5,0" MinHeight="0" Height="18"
                  Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="3">
              <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         FontSize="9" VerticalAlignment="Center" />
              <TextBlock Text="{loc:Str ShowDiff}" FontSize="9" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </sc:StrataAiToolCall.HeaderAction>
      </sc:StrataAiToolCall>
    </DataTemplate>

    <!-- ── Terminal preview (inside tool group) ─────── -->
    <DataTemplate DataType="vm:TerminalPreviewItem">
      <sc:StrataTerminalPreview ToolName="{Binding ToolName}"
                                Command="{Binding Command}"
                                Output="{Binding Output}"
                                Status="{Binding Status}"
                                DurationMs="{Binding DurationMs}"
                                IsExpanded="{Binding IsExpanded}" />
    </DataTemplate>

    <!-- ── Todo progress (inside tool group) ────────── -->
    <DataTemplate DataType="vm:TodoProgressItem">
      <sc:StrataAiToolCall ToolName="{Binding ToolName}"
                           Status="{Binding Status}"
                           IsExpanded="{Binding IsExpanded}"
                           InputParameters="{Binding InputParameters}"
                           MoreInfo="{Binding MoreInfo}" />
    </DataTemplate>

    <!-- ── Question card ────────────────────────────── -->
    <DataTemplate DataType="vm:QuestionItem">
      <sc:StrataQuestionCard Question="{Binding Question}"
                             Options="{Binding Options}"
                             AllowFreeText="{Binding AllowFreeText}"
                             AllowMultiSelect="{Binding AllowMultiSelect}"
                             SelectedAnswer="{Binding SelectedAnswer, Mode=TwoWay}"
                             IsAnswered="{Binding IsAnswered, Mode=TwoWay}"
                             IsExpired="{Binding IsExpired}"
                             Margin="0,4" />
    </DataTemplate>

    <!-- ── Typing indicator ─────────────────────────── -->
    <DataTemplate DataType="vm:TypingIndicatorItem">
      <sc:StrataTypingIndicator Label="{Binding Label}"
                                IsActive="{Binding IsActive}" />
    </DataTemplate>

    <!-- ── Turn summary ─────────────────────────────── -->
    <DataTemplate DataType="vm:TurnSummaryItem">
      <sc:StrataTurnSummary Label="{Binding Label}"
                            IsExpanded="{Binding IsExpanded}"
                            HasFailures="{Binding HasFailures}">
        <sc:StrataTurnSummary.Content>
          <ItemsControl ItemsSource="{Binding InnerItems}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Spacing="8" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </sc:StrataTurnSummary.Content>
      </sc:StrataTurnSummary>
    </DataTemplate>

  </UserControl.DataTemplates>

  <Panel DragDrop.AllowDrop="True">
    <!-- Drop overlay -->
    <Panel x:Name="DropOverlay" IsVisible="False" IsHitTestVisible="False"
           ZIndex="100">
      <!-- Dimming backdrop -->
      <Border Background="{DynamicResource Brush.Surface0}" Opacity="0.85" />
      <!-- Accent border inset -->
      <Border Margin="16" CornerRadius="12" BorderThickness="2"
              BorderBrush="{DynamicResource Brush.AccentDefault}" />
      <!-- Centered content -->
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <Border Width="56" Height="56" CornerRadius="28"
                Background="{DynamicResource Brush.AccentSubtle}"
                HorizontalAlignment="Center">
          <Viewbox Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Canvas Width="24" Height="24">
              <!-- Upload/drop arrow icon -->
              <Path Stroke="{DynamicResource Brush.AccentDefault}"
                    StrokeThickness="2.2" StrokeLineCap="Round"
                    Data="M12,2 L12,16 M12,2 L7,7 M12,2 L17,7" />
              <Path Stroke="{DynamicResource Brush.AccentDefault}"
                    StrokeThickness="2.2" StrokeLineCap="Round"
                    Data="M4,17 L4,20 C4,21.1 4.9,22 6,22 L18,22 C19.1,22 20,21.1 20,20 L20,17" />
            </Canvas>
          </Viewbox>
        </Border>
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Text="{loc:Str DragDrop_Hint}" Classes="body-strong" FontSize="15"
                     Foreground="{DynamicResource Brush.AccentDefault}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Str DragDrop_Subhint}" Classes="caption"
                     Foreground="{DynamicResource Brush.TextTertiary}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Panel>

    <!-- Welcome state (no active chat) -->
    <Panel x:Name="WelcomePanel" Classes.active="{Binding IsWelcomeVisible}">
      <!-- Centered greeting (offset up to leave room for composer) -->
      <StackPanel x:Name="WelcomeGreeting" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16"
                  MaxWidth="560" Margin="0,0,0,120">
        <Border x:Name="WelcomeOrb" Width="64" Height="64" CornerRadius="14"
                HorizontalAlignment="Center" Opacity="0.9" ClipToBounds="True">
          <Image Source="avares://Lumi/Assets/lumi-icon.png"
                 Width="64" Height="64"
                 RenderOptions.BitmapInterpolationMode="HighQuality" />
        </Border>

        <StackPanel Spacing="6" HorizontalAlignment="Center">
          <TextBlock Classes="headline" Text="{loc:Str Chat_WelcomeTitle}"
                     HorizontalAlignment="Center" />
          <TextBlock Classes="secondary" TextAlignment="Center" TextWrapping="Wrap"
                     Text="{loc:Str Chat_WelcomeSubtitle}" />
        </StackPanel>

        <!-- Welcome suggestion chips -->
        <WrapPanel x:Name="WelcomeSuggestions" Margin="0,16,0,0">
          <Button Classes="transcript-suggestion" Margin="0,0,8,8"
                  Command="{Binding SelectSuggestionCommand}"
                  CommandParameter="{loc:Str Chat_SuggestionA}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="☀️" />
              <TextBlock Text="{loc:Str Chat_SuggestionA}" />
            </StackPanel>
          </Button>
          <Button Classes="transcript-suggestion" Margin="0,0,8,8"
                  Command="{Binding SelectSuggestionCommand}"
                  CommandParameter="{loc:Str Chat_SuggestionB}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="🔍" />
              <TextBlock Text="{loc:Str Chat_SuggestionB}" />
            </StackPanel>
          </Button>
          <Button Classes="transcript-suggestion" Margin="0,0,8,8"
                  Command="{Binding SelectSuggestionCommand}"
                  CommandParameter="{loc:Str Chat_SuggestionC}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="📄" />
              <TextBlock Text="{loc:Str Chat_SuggestionC}" />
            </StackPanel>
          </Button>
        </WrapPanel>
      </StackPanel>
    </Panel>

    <!-- Loading overlay shown while chat history is being rebuilt (outside ChatPanel so it's visible even from welcome screen) -->
    <Panel x:Name="LoadingOverlay" IsVisible="{Binding IsLoadingChat}" ZIndex="50" IsHitTestVisible="False">
      <Border Background="{DynamicResource Brush.Surface0}" Opacity="0.85" />
      <sc:StrataTypingIndicator x:Name="LoadingIndicator"
                                Label="{loc:Str Chat_Loading}"
                                IsActive="True"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
    </Panel>

    <!-- Active chat -->
    <Panel x:Name="ChatPanel" Classes.active="{Binding IsChatVisible}">
      <sc:StrataChatShell x:Name="ChatShell" IsOnline="True">

        <sc:StrataChatShell.Header>
          <DockPanel Margin="0,0,8,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center" Margin="8,0,0,0">
              <Border IsVisible="{Binding HasProjectBadge}"
                      Background="{DynamicResource Brush.SurfaceSubtle}" CornerRadius="12" Padding="10,4">
                <TextBlock Classes="caption" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextSecondary}"
                           Text="{Binding ProjectBadgeText}" />
              </Border>
              <Border IsVisible="{Binding HasAgentBadge}"
                      Background="{DynamicResource Brush.AccentSubtle}" CornerRadius="12" Padding="10,4">
                <TextBlock Classes="caption" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.AccentDefault}"
                           Text="{Binding AgentBadgeText}" />
              </Border>
              <Button x:Name="BrowserToggleButton" Classes="subtle"
                      IsVisible="{Binding ShowBrowserToggle}"
                      Classes.open="{Binding IsBrowserOpen}"
                      Command="{Binding ToggleBrowserVisibilityCommand}"
                      ToolTip.Tip="{loc:Str Browser_ShowBrowser}"
                      Padding="7,4" CornerRadius="12">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <PathIcon x:Name="BrowserToggleIcon" Width="12" Height="12"
                            Foreground="{DynamicResource Brush.TextSecondary}"
                            Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" />
                  <TextBlock x:Name="BrowserToggleText" Classes="caption" FontWeight="SemiBold"
                             Foreground="{DynamicResource Brush.TextSecondary}" Text="Browser" />
                </StackPanel>
              </Button>
            </StackPanel>
            <!-- Avatar is fixed, title fills remaining space and trims -->
            <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="7"
                    Background="{DynamicResource Brush.AccentGradient}" Margin="0,0,10,0">
              <TextBlock Text="{loc:Str Chat_AvatarLetter}" FontSize="12" FontWeight="Bold"
                         Foreground="{DynamicResource Brush.TextOnAccent}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Classes="body-strong" Text="{Binding CurrentChatTitle}"
                       ToolTip.Tip="{Binding CurrentChatTitle}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
          </DockPanel>
        </sc:StrataChatShell.Header>



        <sc:StrataChatShell.Transcript>
          <ItemsControl x:Name="Transcript"
                        ItemsSource="{Binding MountedTranscriptTurns}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:TranscriptTurn">
                <vm:TranscriptTurnControl Turn="{Binding}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </sc:StrataChatShell.Transcript>

        <sc:StrataChatShell.Composer>
          <!-- Transparent spacer — reserves space so the transcript doesn't scroll behind the real composer -->
          <Panel x:Name="ComposerSpacer" />
        </sc:StrataChatShell.Composer>

      </sc:StrataChatShell>

  <Border IsVisible="{Binding ShowTranscriptDiagnostics}"
      HorizontalAlignment="Right"
      VerticalAlignment="Top"
      Margin="0,72,12,0"
      MaxWidth="360"
      Padding="10,8"
      CornerRadius="12"
      Background="#CC101521"
      BorderBrush="#404E6B"
      BorderThickness="1"
      ZIndex="6">
    <TextBlock Classes="caption"
       Foreground="#FFDDE7F7"
       FontFamily="Consolas, Cascadia Code, monospace"
       TextWrapping="Wrap"
       Text="{Binding TranscriptDiagnosticsText}" />
  </Border>
    </Panel>

    <!-- Single composer — always visible, animates between welcome and active states -->
    <StackPanel x:Name="ComposerContainer" VerticalAlignment="Bottom" ZIndex="5"
                HorizontalAlignment="Stretch" Spacing="4"
                Classes.welcome="{Binding IsWelcomeVisible}">

      <!-- Suggestion loading pills (shown while generating) -->
      <StackPanel x:Name="SuggestionLoadingRow"
                  Orientation="Horizontal"
                  Margin="4,0,4,0" Spacing="8"
                  IsVisible="{Binding IsSuggestionsGenerating}"
                  IsHitTestVisible="False">
        <Border Classes="suggestion-pill pill-a" Width="120" />
        <Border Classes="suggestion-pill pill-b" Width="148" />
        <Border Classes="suggestion-pill pill-c" Width="104" />
      </StackPanel>

      <!-- Suggestion chips (shown after generation, above composer) -->
      <WrapPanel x:Name="SuggestionChipsRow"
                 Margin="4,0,4,0"
                 Classes.visible="{Binding HasSuggestions}">
        <Button Classes="transcript-suggestion" Margin="0,0,8,4"
                Command="{Binding SelectSuggestionCommand}"
                CommandParameter="{Binding SuggestionA}"
                IsVisible="{Binding SuggestionA, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <TextBlock Text="{Binding SuggestionA}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="320" />
        </Button>
        <Button Classes="transcript-suggestion" Margin="0,0,8,4"
                Command="{Binding SelectSuggestionCommand}"
                CommandParameter="{Binding SuggestionB}"
                IsVisible="{Binding SuggestionB, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <TextBlock Text="{Binding SuggestionB}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="320" />
        </Button>
        <Button Classes="transcript-suggestion" Margin="0,0,8,4"
                Command="{Binding SelectSuggestionCommand}"
                CommandParameter="{Binding SuggestionC}"
                IsVisible="{Binding SuggestionC, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <TextBlock Text="{Binding SuggestionC}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="320" />
        </Button>
      </WrapPanel>

      <!-- Info strip (coding project + token usage) — above the composer -->
      <Border x:Name="CodingStrip" IsVisible="{Binding ShowInfoStrip}" Margin="4,0,4,0"
              RenderTransformOrigin="0.5,1">
        <Border.RenderTransform>
          <TranslateTransform />
        </Border.RenderTransform>
        <Grid ColumnDefinitions="*,Auto">
          <!-- Left: coding project controls -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5"
                      IsVisible="{Binding IsCodingProject}">
          <Button Classes="subtle" Padding="5,1" MinHeight="0" Height="20" CornerRadius="4"
                  IsVisible="{Binding GitBranch, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Cursor="Hand" Background="{DynamicResource Brush.Surface2}">
            <Button.Flyout>
              <MenuFlyout Placement="TopEdgeAlignedLeft">
                <MenuItem Header="{loc:Str Git_OpenTerminal}" Command="{Binding OpenInTerminalCommand}">
                  <MenuItem.Icon>
                    <PathIcon Width="14" Height="14" Data="M5.828 4.086a.5.5 0 0 1 .707 0l3.535 3.535a.5.5 0 0 1 0 .707L6.535 11.864a.5.5 0 0 1-.707-.707L9.01 7.975 5.828 4.793a.5.5 0 0 1 0-.707zM12.5 11.5h-4a.5.5 0 0 0 0 1h4a.5.5 0 0 0 0-1z" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{loc:Str Git_OpenExplorer}" Command="{Binding OpenInExplorerCommand}">
                  <MenuItem.Icon>
                    <PathIcon Width="14" Height="14" Data="M3 3a2 2 0 0 0-2 2v2h20V5a2 2 0 0 0-2-2H3zm18 6H3v8a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9z" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{loc:Str Git_OpenIDE}" Command="{Binding OpenInIDECommand}">
                  <MenuItem.Icon>
                    <PathIcon Width="14" Height="14" Data="M9.954 2.217a.5.5 0 0 1 .273.654L6.326 13.289a.5.5 0 0 1-.927-.382L9.3 2.49a.5.5 0 0 1 .654-.273zM3.694 7.217l-2.4 2.4a.5.5 0 0 0 0 .707l2.4 2.4a.5.5 0 1 1-.707.707L.294 10.738a1.5 1.5 0 0 1 0-2.121l2.693-2.107a.5.5 0 0 1 .707.707zm9.612 0 2.4 2.4a.5.5 0 0 1 0 .707l-2.4 2.4a.5.5 0 0 0 .707.707l2.693-2.107a1.5 1.5 0 0 0 0-2.121L13.999 6.51a.5.5 0 0 0-.707.707z" />
                  </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="{loc:Str Git_CopyBranch}" Command="{Binding CopyBranchNameCommand}">
                  <MenuItem.Icon>
                    <PathIcon Width="14" Height="14" Data="M6 3v6a3 3 0 0 0 3 3h2a1 1 0 0 1 1 1v2m0 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0zM6 3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 0V9" />
                  </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{loc:Str Git_CopyPath}" Command="{Binding CopyDirectoryPathCommand}">
                  <MenuItem.Icon>
                    <PathIcon Width="14" Height="14" Data="M8 1H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm0 1a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h4zm4 3h-1V4h1a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H8v-1h4a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1z" />
                  </MenuItem.Icon>
                </MenuItem>
                <Separator IsVisible="{Binding HasAvailableWorktrees}" />
                <MenuItem Header="{loc:Str Git_ExistingWorktrees}"
                          ItemsSource="{Binding AvailableWorktrees}"
                          IsVisible="{Binding HasAvailableWorktrees}"
                          IsEnabled="{Binding !IsWorktreeLocked}">
                  <MenuItem.Icon>
                    <PathIcon Width="14" Height="14" Data="M4 2a2 2 0 0 0-2 2v1h20V4a2 2 0 0 0-2-2H4zm16 5H4v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7zm-7 2a1 1 0 0 1 1 1v2h2a1 1 0 1 1 0 2h-2v2a1 1 0 1 1-2 0v-2H10a1 1 0 1 1 0-2h2v-2a1 1 0 0 1 1-1z" />
                  </MenuItem.Icon>
                  <MenuItem.ItemContainerTheme>
                    <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="services:WorktreeInfo">
                      <Setter Property="Header" Value="{Binding DisplayName}" />
                      <Setter Property="Command" Value="{Binding $parent[ItemsControl].((vm:ChatViewModel)DataContext).SelectExistingWorktreeCommand}" />
                      <Setter Property="CommandParameter" Value="{Binding Path}" />
                      <Setter Property="Icon">
                        <Template>
                          <PathIcon Width="14" Height="14" Data="M6 3v6a3 3 0 0 0 3 3h2a1 1 0 0 1 1 1v2m0 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0zM6 3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 0V9" />
                        </Template>
                      </Setter>
                    </ControlTheme>
                  </MenuItem.ItemContainerTheme>
                </MenuItem>
              </MenuFlyout>
            </Button.Flyout>
            <StackPanel Orientation="Horizontal" Spacing="3">
              <PathIcon Width="8" Height="8" Foreground="{DynamicResource Brush.TextTertiary}"
                        Data="M6 3v6a3 3 0 0 0 3 3h2a1 1 0 0 1 1 1v2m0 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0zM6 3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm0 0V9" />
              <TextBlock Text="{Binding GitBranch}" FontSize="10"
                         Foreground="{DynamicResource Brush.TextTertiary}" VerticalAlignment="Center"
                         MaxWidth="120" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </Button>
          <!-- Local / Worktree toggle -->
          <Border Background="{DynamicResource Brush.Surface2}" CornerRadius="4" Padding="1">
            <Panel>
              <!-- Sliding highlight pill -->
              <Border x:Name="WorktreeToggleHighlight"
                      Background="{DynamicResource Brush.Surface0}"
                      CornerRadius="3"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Stretch"
                      IsHitTestVisible="False">
                <Border.Transitions>
                  <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.2" Easing="CubicEaseOut" />
                    <ThicknessTransition Property="Margin" Duration="0:0:0.2" Easing="CubicEaseOut" />
                  </Transitions>
                </Border.Transitions>
              </Border>
              <!-- Toggle buttons -->
              <StackPanel x:Name="WorktreeTogglePanel" Orientation="Horizontal" Spacing="1">
                <Button x:Name="LocalToggleBtn" Classes="subtle" Padding="5,1" MinHeight="0" Height="20" CornerRadius="3"
                        Command="{Binding ToggleWorktreePreChatCommand}"
                        IsEnabled="{Binding !IsWorktreeLocked}"
                        ToolTip.Tip="{loc:Str Git_LocalTooltip}"
                        Background="Transparent" Cursor="Hand">
                  <TextBlock Text="{loc:Str Git_Local}" FontSize="10"
                             Classes="wt-label" Classes.inactive="{Binding IsWorktreeMode}" />
                </Button>
                <Button x:Name="WorktreeToggleBtn" Classes="subtle" Padding="5,1" MinHeight="0" Height="20" CornerRadius="3"
                        Command="{Binding ToggleWorktreePreChatCommand}"
                        IsEnabled="{Binding !IsWorktreeLocked}"
                        ToolTip.Tip="{loc:Str Git_WorktreeTooltip}"
                        Background="Transparent" Cursor="Hand">
                  <TextBlock Text="{loc:Str Git_Worktree}" FontSize="10"
                             Classes="wt-label" Classes.inactive="{Binding !IsWorktreeMode}" />
                </Button>
              </StackPanel>
            </Panel>
          </Border>
        <Button Classes="subtle" Padding="5,1" MinHeight="0" Height="20" CornerRadius="4"
                Command="{Binding ShowGitChangesCommand}" IsVisible="{Binding HasGitChanges}"
                ToolTip.Tip="{loc:Str Git_ShowChanges}" Cursor="Hand">
          <StackPanel Orientation="Horizontal" Spacing="3">
            <Border Width="6" Height="6" CornerRadius="3" Background="{DynamicResource Brush.Warning}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding GitChangesLabel}" FontSize="10" Foreground="{DynamicResource Brush.TextSecondary}" />
          </StackPanel>
        </Button>
        <Border Background="{DynamicResource Brush.Surface2}" CornerRadius="4" Padding="5,1"
                IsVisible="{Binding IsRefreshingGitStatus}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border x:Name="GitRefreshDot" Width="6" Height="6" CornerRadius="3"
                    Background="{DynamicResource Brush.AccentDefault}" VerticalAlignment="Center">
              <Border.Styles>
                <Style Selector="Border#GitRefreshDot">
                  <Style.Animations>
                    <Animation Duration="0:0:0.9" IterationCount="INFINITE" PlaybackDirection="Alternate">
                      <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                      <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.25"/></KeyFrame>
                    </Animation>
                  </Style.Animations>
                </Style>
              </Border.Styles>
            </Border>
            <TextBlock Text="{loc:Str Git_Refreshing}" FontSize="10"
                       Foreground="{DynamicResource Brush.TextSecondary}" />
          </StackPanel>
        </Border>
        <Button Classes="subtle" Padding="2,1" MinHeight="0" Height="20" Width="20" CornerRadius="4"
                Command="{Binding RefreshGitStatusCommand}" ToolTip.Tip="{loc:Str Git_RefreshTooltip}" Cursor="Hand"
                IsEnabled="{Binding !IsRefreshingGitStatus}">
          <PathIcon Width="9" Height="9" Foreground="{DynamicResource Brush.TextTertiary}"
                    Data="M17.65 6.35A8 8 0 1 0 19.73 13h-2.08A6 6 0 1 1 12 6a5.97 5.97 0 0 1 4.24 1.76L13 11h7V4l-2.35 2.35z" />
        </Button>
          </StackPanel>

          <!-- Right: token usage -->
          <Border Grid.Column="1"
                  IsVisible="{Binding HasTokenUsage}"
                  Padding="8,1,8,1"
                  CornerRadius="8"
                  Background="{DynamicResource Brush.Surface2}"
                  Opacity="0.7"
                  Cursor="Hand"
                  VerticalAlignment="Center">
            <Border.Transitions>
              <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
              </Transitions>
            </Border.Transitions>
            <ToolTip.Tip>
              <StackPanel Spacing="6" MinWidth="180">
                <TextBlock Text="Token Usage" FontWeight="SemiBold" FontSize="12"
                           Foreground="{DynamicResource Brush.TextPrimary}" />
                <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="0,2,0,0">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Input" FontSize="11"
                             Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TokenInputDisplay}" FontSize="11"
                             Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Right" Margin="16,0,0,0" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Output" FontSize="11" Margin="0,4,0,0"
                             Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TokenOutputDisplay}" FontSize="11" Margin="16,4,0,0"
                             Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Right" />
                </Grid>
                <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Total" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Brush.TextPrimary}" />
                  <TextBlock Grid.Column="1" Text="{Binding TokenTotalDisplay}" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Brush.AccentDefault}" HorizontalAlignment="Right" Margin="16,0,0,0" />
                </Grid>
                <!-- Context window usage (only when available) -->
                <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}"
                        IsVisible="{Binding HasContextUsage}" />
                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasContextUsage}">
                  <TextBlock Grid.Column="0" Text="Context window" FontSize="11"
                             Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Column="1" Text="{Binding ContextUsageDisplay}" FontSize="11"
                             Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Right" Margin="16,0,0,0" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasContextUsage}" Margin="0,-2,0,0">
                  <TextBlock Grid.Column="0" Text="Usage" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Brush.TextPrimary}" />
                  <TextBlock Grid.Column="1" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource Brush.AccentDefault}" HorizontalAlignment="Right" Margin="16,0,0,0">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0}%">
                        <Binding Path="ContextUsagePercent" />
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </Grid>
              </StackPanel>
            </ToolTip.Tip>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <PathIcon Width="10" Height="10"
                        Foreground="{DynamicResource Brush.TextTertiary}"
                        Data="M13 10V3L4 14h7v7l9-11h-7z" />
              <TextBlock Text="{Binding TokenUsageSummary}"
                         FontSize="10.5"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         VerticalAlignment="Center" />
              <TextBlock Text="{Binding TokenUsageSuffixText}"
                         FontSize="10.5"
                         Foreground="{DynamicResource Brush.TextTertiary}"
                         Opacity="0.7"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <sc:StrataChatComposer x:Name="Composer"
                             Placeholder="{loc:Str Chat_Placeholder}"
                             PromptText="{Binding PromptText, Mode=TwoWay}"
                             IsBusy="{Binding IsBusy}"
                             IsRecording="{Binding IsRecording}"
                             SendWithEnter="{Binding SendWithEnter}"
                             SendCommand="{Binding SendMessageCommand}"
                             StopCommand="{Binding StopGenerationCommand}"
                             AttachCommand="{Binding RequestAttachFilesCommand}"
                             VoiceCommand="{Binding ToggleVoiceCommand}"
                             AgentRemovedCommand="{Binding RemoveAgentCommand}"
                             ProjectRemovedCommand="{Binding RemoveProjectCommand}"
                             SkillRemovedCommand="{Binding RemoveSkillCommand}"
                             McpRemovedCommand="{Binding RemoveMcpCommand}"
                             FileQueryChangedCommand="{Binding HandleFileQueryCommand}"
                             FileSelectedCommand="{Binding HandleFileSelectionCommand}"
                             ClipboardPasteCommand="{Binding RequestClipboardPasteCommand}"
                             Models="{Binding AvailableModels}"
                             SelectedModel="{Binding SelectedModel, Mode=TwoWay}"
                             QualityLevels="{Binding QualityLevels}"
                             AgentName="{Binding SelectedAgentName, Mode=TwoWay}"
                             AgentGlyph="{Binding SelectedAgentGlyph}"
                             ProjectName="{Binding SelectedProjectName, Mode=TwoWay}"
                             SkillItems="{Binding ActiveSkillChips}"
                             McpItems="{Binding ActiveMcpChips}"
                             AvailableAgents="{Binding AvailableAgentChips}"
                             AvailableSkills="{Binding AvailableSkillChips}"
                             AvailableMcps="{Binding AvailableMcpChips}"
                             AvailableProjects="{Binding AvailableProjectChips}"
                             AvailableFiles="{Binding AvailableFileSuggestions}">
        <sc:StrataChatComposer.ModelItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Converter={StaticResource ModelDisplayConverter}}" />
          </DataTemplate>
        </sc:StrataChatComposer.ModelItemTemplate>
        <sc:StrataChatComposer.AttachmentContent>
          <sc:StrataAttachmentList ShowAddButton="False"
                                   ItemsSource="{Binding PendingAttachmentItems}"
                                   IsVisible="{Binding HasPendingAttachments}">
            <sc:StrataAttachmentList.ItemTemplate>
              <DataTemplate DataType="vm:FileAttachmentItem">
                <sc:StrataFileAttachment FileName="{Binding FileName}"
                                         FileSize="{Binding FileSize}"
                                         IconImage="{Binding IconImage}"
                                         Status="Completed"
                                         IsCompact="True"
                                         IsRemovable="{Binding IsRemovable}"
                                         RemoveCommand="{Binding RemoveCommand}"
                                         Margin="0,0,6,4" />
              </DataTemplate>
            </sc:StrataAttachmentList.ItemTemplate>
          </sc:StrataAttachmentList>
        </sc:StrataChatComposer.AttachmentContent>
      </sc:StrataChatComposer>
    </StackPanel>
  </Panel>
</UserControl>
