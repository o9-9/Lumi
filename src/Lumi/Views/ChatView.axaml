<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumi.ViewModels"
             xmlns:sc="using:StrataTheme.Controls"
             xmlns:loc="using:Lumi.Localization"
             x:Class="Lumi.Views.ChatView"
             x:DataType="vm:ChatViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <!-- Show Retry on user messages (theme hides it) -->
    <Style Selector="sc|StrataChatMessage:user /template/ Button#PART_RegenerateButton">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <!-- Hide entire action toolbar on assistant messages -->
    <Style Selector="sc|StrataChatMessage:assistant /template/ Border#PART_ActionLayer">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <!-- Compact tool calls: hide the status pill and reduce padding -->
    <Style Selector="sc|StrataAiToolCall.compact /template/ Border#PART_StatusPill">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="sc|StrataAiToolCall.compact /template/ Border#PART_Header">
      <Setter Property="Padding" Value="8,3" />
    </Style>
    <Style Selector="Button#BrowserToggleButton.open">
      <Setter Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
    </Style>
    <Style Selector="Button#BrowserToggleButton.open TextBlock#BrowserToggleText">
      <Setter Property="Foreground" Value="{DynamicResource Brush.AccentDefault}" />
    </Style>
    <Style Selector="Button#BrowserToggleButton.open PathIcon#BrowserToggleIcon">
      <Setter Property="Foreground" Value="{DynamicResource Brush.AccentDefault}" />
    </Style>
  </UserControl.Styles>

  <UserControl.DataTemplates>

    <!-- ── User message ─────────────────────────────── -->
    <DataTemplate DataType="vm:UserMessageItem">
      <sc:StrataChatMessage Role="User"
                            HorizontalAlignment="Right"
                            MaxWidth="560"
                            Author="{Binding Author}"
                            Timestamp="{Binding TimestampText}"
                            IsEditable="True"
                            EditText="{Binding Content, Mode=OneWay}"
                            EditCommand="{Binding BeginEditCommand}"
                            EditConfirmedCommand="{Binding ConfirmEditCommand}"
                            RegenerateCommand="{Binding ResendCommand}">
        <sc:StrataChatMessage.Content>
          <StackPanel Spacing="6">
            <sc:StrataMarkdown Markdown="{Binding Content}" IsInline="True" />
            <ItemsControl ItemsSource="{Binding Attachments}"
                          IsVisible="{Binding HasAttachments}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:FileAttachmentItem">
                  <sc:StrataFileAttachment FileName="{Binding FileName}"
                                           FileSize="{Binding FileSize}"
                                           Status="Completed"
                                           IsRemovable="False" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl ItemsSource="{Binding Skills}"
                          IsVisible="{Binding HasSkills}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                          CornerRadius="10" Padding="8,3" Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="{Binding Glyph}" FontSize="11" VerticalAlignment="Center" />
                      <TextBlock Text="{Binding Name}" Classes="caption"
                                 Foreground="{DynamicResource Brush.TextSecondary}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </sc:StrataChatMessage.Content>
      </sc:StrataChatMessage>
    </DataTemplate>

    <!-- ── Assistant message ────────────────────────── -->
    <DataTemplate DataType="vm:AssistantMessageItem">
      <sc:StrataChatMessage Role="Assistant"
                            Author="{Binding Author}"
                            Timestamp="{Binding TimestampText}"
                            IsStreaming="{Binding IsStreaming}">
        <sc:StrataChatMessage.Content>
          <StackPanel Spacing="6">
            <sc:StrataMarkdown Markdown="{Binding Content}" IsInline="True" />

            <!-- Skills section -->
            <ItemsControl ItemsSource="{Binding Skills}"
                          IsVisible="{Binding HasSkills}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                          CornerRadius="10" Padding="8,3" Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="{Binding Glyph}" FontSize="11" VerticalAlignment="Center" />
                      <TextBlock Text="{Binding Name}" Classes="caption"
                                 Foreground="{DynamicResource Brush.TextSecondary}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- File attachments -->
            <ItemsControl ItemsSource="{Binding FileAttachments}"
                          IsVisible="{Binding HasFileAttachments}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:FileAttachmentItem">
                  <sc:StrataFileAttachment FileName="{Binding FileName}"
                                           FileSize="{Binding FileSize}"
                                           Status="Completed"
                                           IsRemovable="False" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Sources section -->
            <sc:StrataThink Label="{Binding SourcesLabel}"
                            IsVisible="{Binding HasSources}">
              <sc:StrataThink.Content>
                <ItemsControl ItemsSource="{Binding Sources}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Spacing="2" /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:SourceItem">
                      <Button Classes="subtle" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Command="{Binding OpenCommand}"
                              Padding="6,4" Cursor="Hand">
                        <StackPanel>
                          <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                     Classes="caption" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Domain}" Classes="caption"
                                     Foreground="{DynamicResource Brush.TextTertiary}" />
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </sc:StrataThink.Content>
            </sc:StrataThink>

          </StackPanel>
        </sc:StrataChatMessage.Content>
      </sc:StrataChatMessage>
    </DataTemplate>

    <!-- ── File changes summary (separate item at end of turn) ── -->
    <DataTemplate DataType="vm:FileChangesSummaryItem">
      <sc:StrataThink Label="{Binding Label}">
        <sc:StrataThink.HeaderExtra>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{Binding TotalStatsAdded}"
                       FontSize="{DynamicResource Font.SizeCaption}" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.SuccessDefault}" />
            <TextBlock Text="{Binding TotalStatsRemoved}"
                       FontSize="{DynamicResource Font.SizeCaption}" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.DangerDefault}"
                       IsVisible="{Binding HasTotalRemovals}" />
          </StackPanel>
        </sc:StrataThink.HeaderExtra>
        <sc:StrataThink.Content>
          <ItemsControl ItemsSource="{Binding FileChanges}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Spacing="2" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:FileChangeItem">
                <Button Classes="subtle" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowDiffCommand}"
                        Padding="6,4" Cursor="Hand">
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding ActionIcon}" Margin="0,0,6,0"
                               FontSize="13" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center" Margin="8,0,0,0">
                      <TextBlock Text="{Binding StatsAdded}"
                                 FontSize="{DynamicResource Font.SizeCaption}" FontWeight="Medium"
                                 Foreground="{DynamicResource Brush.SuccessDefault}" />
                      <TextBlock Text="{Binding StatsRemoved}"
                                 FontSize="{DynamicResource Font.SizeCaption}" FontWeight="Medium"
                                 Foreground="{DynamicResource Brush.DangerDefault}"
                                 IsVisible="{Binding HasRemovals}" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="{Binding FileName}" Classes="caption" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Directory}" Classes="caption"
                                 Foreground="{DynamicResource Brush.TextTertiary}"
                                 TextTrimming="CharacterEllipsis"
                                 IsVisible="{Binding Directory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </DockPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Plan card (inline in transcript when agent creates/updates a plan) ── -->
    <DataTemplate DataType="vm:PlanCardItem">
      <sc:StrataThink Label="{Binding StatusText}">
        <sc:StrataThink.HeaderExtra>
          <TextBlock Text="📋"
                     FontSize="{DynamicResource Font.SizeCaption}"
                     VerticalAlignment="Center" />
        </sc:StrataThink.HeaderExtra>
        <sc:StrataThink.Content>
          <Button Classes="subtle" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left"
                  Command="{Binding OpenCommand}"
                  Padding="6,4" Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Width="13" Height="13" Foreground="{DynamicResource Brush.AccentDefault}"
                        VerticalAlignment="Center">
                <PathIcon.Data>
                  <StreamGeometry>M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM17.99 9l-1.41-1.42-6.59 6.59-2.58-2.57-1.42 1.41 4 3.99z</StreamGeometry>
                </PathIcon.Data>
              </PathIcon>
              <TextBlock Text="View plan" Classes="caption" FontWeight="SemiBold"
                         Foreground="{DynamicResource Brush.AccentDefault}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Error message ─────────────────────────────── -->
    <DataTemplate DataType="vm:ErrorMessageItem">
      <Border Background="{DynamicResource Brush.DangerSubtle}"
              CornerRadius="12" Padding="14,12" Margin="0,4">
        <StackPanel Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="⚠" FontSize="14" VerticalAlignment="Center"
                       Foreground="{DynamicResource Brush.DangerDefault}" />
            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.DangerDefault}"
                       FontWeight="SemiBold" FontSize="13" />
          </StackPanel>
        </StackPanel>
      </Border>
    </DataTemplate>

    <!-- ── Reasoning block ──────────────────────────── -->
    <DataTemplate DataType="vm:ReasoningItem">
      <sc:StrataThink Label="{loc:Str Tool_ReasoningLabel}"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}">
        <sc:StrataThink.Content>
          <sc:StrataMarkdown Markdown="{Binding Content}" IsInline="True" />
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Tool group (collapsible) ─────────────────── -->
    <DataTemplate DataType="vm:ToolGroupItem">
      <sc:StrataThink Label="{Binding Label}"
                      Meta="{Binding Meta}"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}"
                      ProgressValue="{Binding ProgressValue}">
        <sc:StrataThink.Content>
          <ItemsControl ItemsSource="{Binding ToolCalls}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Spacing="3" Width="440" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Single tool (flattened — StrataThink pill) ── -->
    <DataTemplate DataType="vm:SingleToolItem">
      <sc:StrataThink Label="{Binding Label}"
                      Meta="{Binding Meta}"
                      IsExpanded="{Binding IsExpanded}"
                      IsActive="{Binding IsActive}">
        <sc:StrataThink.HeaderExtra>
          <Button Classes="subtle" Command="{Binding ShowDiffCommand}"
                  IsVisible="{Binding HasDiff}"
                  Padding="5,0" MinHeight="0" Height="18"
                  Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="3">
              <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         FontSize="9" VerticalAlignment="Center" />
              <TextBlock Text="{loc:Str ShowDiff}" FontSize="9" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </sc:StrataThink.HeaderExtra>
        <sc:StrataThink.Content>
          <StackPanel Spacing="6" MaxWidth="440">
            <!-- Regular tool details -->
            <sc:StrataMarkdown Markdown="{Binding InputParameters}" IsInline="True"
                               IsVisible="{Binding InputParameters, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Text="{Binding MoreInfo}" TextWrapping="Wrap"
                       Classes="caption" Foreground="{DynamicResource Brush.TextSecondary}"
                       IsVisible="{Binding MoreInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <!-- Terminal: command + scrollable output -->
            <Border IsVisible="{Binding IsTerminal}"
                    Background="{DynamicResource Brush.Surface1}"
                    CornerRadius="6" Padding="10,8">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="$" FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="12" FontWeight="Bold"
                             Foreground="{DynamicResource Brush.TerminalPreviewPrompt}"
                             VerticalAlignment="Top" />
                  <TextBlock Text="{Binding TerminalCommand}" FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="12" TextWrapping="Wrap"
                             Foreground="{DynamicResource Brush.TerminalPreviewCommand}" />
                </StackPanel>
                <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Disabled"
                              IsVisible="{Binding TerminalOutput, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                  <TextBlock Text="{Binding TerminalOutput}" FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource Brush.TerminalPreviewOutput}" />
                </ScrollViewer>
              </StackPanel>
            </Border>
          </StackPanel>
        </sc:StrataThink.Content>
      </sc:StrataThink>
    </DataTemplate>

    <!-- ── Regular tool call (inside tool group) ────── -->
    <DataTemplate DataType="vm:ToolCallItem">
      <sc:StrataAiToolCall ToolName="{Binding ToolName}"
                           Classes.compact="{Binding IsCompact}"
                           Status="{Binding Status}"
                           IsExpanded="{Binding IsExpanded}"
                           InputParameters="{Binding InputParameters}"
                           MoreInfo="{Binding MoreInfo}"
                           DurationMs="{Binding DurationMs}">
        <sc:StrataAiToolCall.HeaderAction>
          <Button Classes="subtle" Command="{Binding ShowDiffCommand}"
                  IsVisible="{Binding HasDiff}"
                  Padding="5,0" MinHeight="0" Height="18"
                  Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="3">
              <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         FontSize="9" VerticalAlignment="Center" />
              <TextBlock Text="{loc:Str ShowDiff}" FontSize="9" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </sc:StrataAiToolCall.HeaderAction>
      </sc:StrataAiToolCall>
    </DataTemplate>

    <!-- ── Terminal preview (inside tool group) ─────── -->
    <DataTemplate DataType="vm:TerminalPreviewItem">
      <sc:StrataTerminalPreview ToolName="{Binding ToolName}"
                                Command="{Binding Command}"
                                Output="{Binding Output}"
                                Status="{Binding Status}"
                                DurationMs="{Binding DurationMs}"
                                IsExpanded="{Binding IsExpanded}" />
    </DataTemplate>

    <!-- ── Todo progress (inside tool group) ────────── -->
    <DataTemplate DataType="vm:TodoProgressItem">
      <sc:StrataAiToolCall ToolName="{Binding ToolName}"
                           Status="{Binding Status}"
                           IsExpanded="{Binding IsExpanded}"
                           InputParameters="{Binding InputParameters}"
                           MoreInfo="{Binding MoreInfo}" />
    </DataTemplate>

    <!-- ── Question card ────────────────────────────── -->
    <DataTemplate DataType="vm:QuestionItem">
      <sc:StrataQuestionCard Question="{Binding Question}"
                             Options="{Binding Options}"
                             AllowFreeText="{Binding AllowFreeText}"
                             SelectedAnswer="{Binding SelectedAnswer, Mode=TwoWay}"
                             IsAnswered="{Binding IsAnswered, Mode=TwoWay}"
                             Margin="0,4" />
    </DataTemplate>

    <!-- ── Typing indicator ─────────────────────────── -->
    <DataTemplate DataType="vm:TypingIndicatorItem">
      <sc:StrataTypingIndicator Label="{Binding Label}"
                                IsActive="{Binding IsActive}" />
    </DataTemplate>

    <!-- ── Turn summary ─────────────────────────────── -->
    <DataTemplate DataType="vm:TurnSummaryItem">
      <sc:StrataTurnSummary Label="{Binding Label}"
                            IsExpanded="{Binding IsExpanded}"
                            HasFailures="{Binding HasFailures}">
        <sc:StrataTurnSummary.Content>
          <ItemsControl ItemsSource="{Binding InnerItems}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Spacing="8" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </sc:StrataTurnSummary.Content>
      </sc:StrataTurnSummary>
    </DataTemplate>

  </UserControl.DataTemplates>

  <Panel DragDrop.AllowDrop="True">
    <!-- Drop overlay -->
    <Panel x:Name="DropOverlay" IsVisible="False" IsHitTestVisible="False"
           ZIndex="100">
      <!-- Dimming backdrop -->
      <Border Background="{DynamicResource Brush.Surface0}" Opacity="0.85" />
      <!-- Accent border inset -->
      <Border Margin="16" CornerRadius="12" BorderThickness="2"
              BorderBrush="{DynamicResource Brush.AccentDefault}" />
      <!-- Centered content -->
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <Border Width="56" Height="56" CornerRadius="28"
                Background="{DynamicResource Brush.AccentSubtle}"
                HorizontalAlignment="Center">
          <Viewbox Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Canvas Width="24" Height="24">
              <!-- Upload/drop arrow icon -->
              <Path Stroke="{DynamicResource Brush.AccentDefault}"
                    StrokeThickness="2.2" StrokeLineCap="Round"
                    Data="M12,2 L12,16 M12,2 L7,7 M12,2 L17,7" />
              <Path Stroke="{DynamicResource Brush.AccentDefault}"
                    StrokeThickness="2.2" StrokeLineCap="Round"
                    Data="M4,17 L4,20 C4,21.1 4.9,22 6,22 L18,22 C19.1,22 20,21.1 20,20 L20,17" />
            </Canvas>
          </Viewbox>
        </Border>
        <StackPanel Spacing="4" HorizontalAlignment="Center">
          <TextBlock Text="{loc:Str DragDrop_Hint}" Classes="body-strong" FontSize="15"
                     Foreground="{DynamicResource Brush.AccentDefault}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Str DragDrop_Subhint}" Classes="caption"
                     Foreground="{DynamicResource Brush.TextTertiary}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Panel>

    <!-- Welcome state (no active chat) -->
    <Panel x:Name="WelcomePanel" IsVisible="{Binding IsWelcomeVisible}">
      <!-- Centered greeting (offset up to leave room for composer) -->
      <StackPanel x:Name="WelcomeGreeting" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16"
                  MaxWidth="480" Margin="0,0,0,120">
        <Border x:Name="WelcomeOrb" Width="64" Height="64" CornerRadius="14"
                HorizontalAlignment="Center" Opacity="0.9" ClipToBounds="True">
          <Image Source="avares://Lumi/Assets/lumi-icon.png"
                 Width="64" Height="64"
                 RenderOptions.BitmapInterpolationMode="HighQuality" />
        </Border>

        <StackPanel Spacing="6" HorizontalAlignment="Center">
          <TextBlock Classes="headline" Text="{loc:Str Chat_WelcomeTitle}"
                     HorizontalAlignment="Center" />
          <TextBlock Classes="secondary" TextAlignment="Center" TextWrapping="Wrap"
                     Text="{loc:Str Chat_WelcomeSubtitle}" />
        </StackPanel>
      </StackPanel>

      <!-- Bottom-pinned composer -->
      <StackPanel VerticalAlignment="Bottom" Spacing="4" MaxWidth="680"
                  HorizontalAlignment="Stretch" Margin="24,0,24,20">
        <sc:StrataAttachmentList ShowAddButton="False"
                                 ItemsSource="{Binding PendingAttachmentItems}"
                                 IsVisible="{Binding HasPendingAttachments}">
          <sc:StrataAttachmentList.ItemTemplate>
            <DataTemplate DataType="vm:FileAttachmentItem">
              <sc:StrataFileAttachment FileName="{Binding FileName}"
                                       FileSize="{Binding FileSize}"
                                       Status="Completed"
                                       IsRemovable="{Binding IsRemovable}"
                                       RemoveCommand="{Binding RemoveCommand}" />
            </DataTemplate>
          </sc:StrataAttachmentList.ItemTemplate>
        </sc:StrataAttachmentList>
        <sc:StrataChatComposer x:Name="WelcomeComposer"
                               Placeholder="{loc:Str Chat_Placeholder}"
                               PromptText="{Binding PromptText, Mode=TwoWay}"
                               IsBusy="{Binding IsBusy}"
                               IsRecording="{Binding IsRecording}"
                               SendWithEnter="{Binding SendWithEnter}"
                               SendCommand="{Binding SendMessageCommand}"
                               StopCommand="{Binding StopGenerationCommand}"
                               AttachCommand="{Binding RequestAttachFilesCommand}"
                               VoiceCommand="{Binding ToggleVoiceCommand}"
                               AgentRemovedCommand="{Binding RemoveAgentCommand}"
                               ProjectRemovedCommand="{Binding RemoveProjectCommand}"
                               SkillRemovedCommand="{Binding RemoveSkillCommand}"
                               McpRemovedCommand="{Binding RemoveMcpCommand}"
                               FileQueryChangedCommand="{Binding HandleFileQueryCommand}"
                               FileSelectedCommand="{Binding HandleFileSelectionCommand}"
                               ClipboardPasteCommand="{Binding RequestClipboardPasteCommand}"
                               Models="{Binding AvailableModels}"
                               SelectedModel="{Binding SelectedModel, Mode=TwoWay}"
                               QualityLevels="{Binding QualityLevels}"
                               SuggestionA="{loc:Str Chat_SuggestionA}"
                               SuggestionB="{loc:Str Chat_SuggestionB}"
                               SuggestionC="{loc:Str Chat_SuggestionC}"
                               AgentName="{Binding SelectedAgentName, Mode=TwoWay}"
                               AgentGlyph="{Binding SelectedAgentGlyph}"
                               ProjectName="{Binding SelectedProjectName, Mode=TwoWay}"
                               SkillItems="{Binding ActiveSkillChips}"
                               McpItems="{Binding ActiveMcpChips}"
                               AvailableAgents="{Binding AvailableAgentChips}"
                               AvailableSkills="{Binding AvailableSkillChips}"
                               AvailableMcps="{Binding AvailableMcpChips}"
                               AvailableProjects="{Binding AvailableProjectChips}"
                               AvailableFiles="{Binding AvailableFileSuggestions}" />
      </StackPanel>
    </Panel>

    <!-- Loading overlay shown while chat history is being rebuilt (outside ChatPanel so it's visible even from welcome screen) -->
    <Panel x:Name="LoadingOverlay" IsVisible="{Binding IsLoadingChat}" ZIndex="50" IsHitTestVisible="False">
      <Border Background="{DynamicResource Brush.Surface0}" Opacity="0.85" />
      <sc:StrataTypingIndicator x:Name="LoadingIndicator"
                                Label="{loc:Str Chat_Loading}"
                                IsActive="True"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
    </Panel>

    <!-- Active chat -->
    <Panel x:Name="ChatPanel" IsVisible="{Binding IsChatVisible}">
      <sc:StrataChatShell x:Name="ChatShell" IsOnline="True">

        <sc:StrataChatShell.Header>
          <DockPanel Margin="0,0,8,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center" Margin="8,0,0,0">
              <Border IsVisible="{Binding HasProjectBadge}"
                      Background="{DynamicResource Brush.SurfaceSubtle}" CornerRadius="12" Padding="10,4">
                <TextBlock Classes="caption" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextSecondary}"
                           Text="{Binding ProjectBadgeText}" />
              </Border>
              <Border IsVisible="{Binding HasAgentBadge}"
                      Background="{DynamicResource Brush.AccentSubtle}" CornerRadius="12" Padding="10,4">
                <TextBlock Classes="caption" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.AccentDefault}"
                           Text="{Binding AgentBadgeText}" />
              </Border>
              <Button x:Name="BrowserToggleButton" Classes="subtle"
                      IsVisible="{Binding ShowBrowserToggle}"
                      Classes.open="{Binding IsBrowserOpen}"
                      Command="{Binding ToggleBrowserVisibilityCommand}"
                      ToolTip.Tip="{loc:Str Browser_ShowBrowser}"
                      Padding="7,4" CornerRadius="12">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <PathIcon x:Name="BrowserToggleIcon" Width="12" Height="12"
                            Foreground="{DynamicResource Brush.TextSecondary}"
                            Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" />
                  <TextBlock x:Name="BrowserToggleText" Classes="caption" FontWeight="SemiBold"
                             Foreground="{DynamicResource Brush.TextSecondary}" Text="Browser" />
                </StackPanel>
              </Button>
            </StackPanel>
            <!-- Avatar is fixed, title fills remaining space and trims -->
            <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="7"
                    Background="{DynamicResource Brush.AccentGradient}" Margin="0,0,10,0">
              <TextBlock Text="{loc:Str Chat_AvatarLetter}" FontSize="12" FontWeight="Bold"
                         Foreground="{DynamicResource Brush.TextOnAccent}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Classes="body-strong" Text="{Binding CurrentChatTitle}"
                       ToolTip.Tip="{Binding CurrentChatTitle}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
          </DockPanel>
        </sc:StrataChatShell.Header>



        <sc:StrataChatShell.Transcript>
          <sc:StrataChatTranscript x:Name="Transcript"
                                  ItemsSource="{Binding TranscriptItems}" />
        </sc:StrataChatShell.Transcript>

        <sc:StrataChatShell.Composer>
          <StackPanel Spacing="4">

            <sc:StrataAttachmentList ShowAddButton="False"
                                     ItemsSource="{Binding PendingAttachmentItems}"
                                     IsVisible="{Binding HasPendingAttachments}">
              <sc:StrataAttachmentList.ItemTemplate>
                <DataTemplate DataType="vm:FileAttachmentItem">
                  <sc:StrataFileAttachment FileName="{Binding FileName}"
                                           FileSize="{Binding FileSize}"
                                           Status="Completed"
                                           IsRemovable="{Binding IsRemovable}"
                                           RemoveCommand="{Binding RemoveCommand}" />
                </DataTemplate>
              </sc:StrataAttachmentList.ItemTemplate>
            </sc:StrataAttachmentList>
            <sc:StrataChatComposer x:Name="ActiveComposer"
                                  Placeholder="{loc:Str Chat_Placeholder}"
                                  PromptText="{Binding PromptText, Mode=TwoWay}"
                                  IsBusy="{Binding IsBusy}"
                                  IsRecording="{Binding IsRecording}"
                                  SendWithEnter="{Binding SendWithEnter}"
                                  SendCommand="{Binding SendMessageCommand}"
                                  StopCommand="{Binding StopGenerationCommand}"
                                  AttachCommand="{Binding RequestAttachFilesCommand}"
                                  VoiceCommand="{Binding ToggleVoiceCommand}"
                                  AgentRemovedCommand="{Binding RemoveAgentCommand}"
                                  ProjectRemovedCommand="{Binding RemoveProjectCommand}"
                                  SkillRemovedCommand="{Binding RemoveSkillCommand}"
                                  McpRemovedCommand="{Binding RemoveMcpCommand}"
                                  FileQueryChangedCommand="{Binding HandleFileQueryCommand}"
                                  FileSelectedCommand="{Binding HandleFileSelectionCommand}"
                                  ClipboardPasteCommand="{Binding RequestClipboardPasteCommand}"
                                  Models="{Binding AvailableModels}"
                                  SelectedModel="{Binding SelectedModel, Mode=TwoWay}"
                                  QualityLevels="{Binding QualityLevels}"
                                  SuggestionA="{Binding SuggestionA}"
                                  SuggestionB="{Binding SuggestionB}"
                                  SuggestionC="{Binding SuggestionC}"
                                  IsSuggestionsGenerating="{Binding IsSuggestionsGenerating}"
                                  AgentName="{Binding SelectedAgentName, Mode=TwoWay}"
                                  AgentGlyph="{Binding SelectedAgentGlyph}"
                                  ProjectName="{Binding SelectedProjectName, Mode=TwoWay}"
                                  SkillItems="{Binding ActiveSkillChips}"
                                  McpItems="{Binding ActiveMcpChips}"
                                  AvailableAgents="{Binding AvailableAgentChips}"
                                  AvailableSkills="{Binding AvailableSkillChips}"
                                  AvailableMcps="{Binding AvailableMcpChips}"
                                  AvailableProjects="{Binding AvailableProjectChips}"
                                  AvailableFiles="{Binding AvailableFileSuggestions}" />
          </StackPanel>
        </sc:StrataChatShell.Composer>

      </sc:StrataChatShell>
    </Panel>
  </Panel>
</UserControl>
